        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "কর্মীদের জন্য সহায়ক অ্যাপ। আপনার ম্যানেজারের লোকাল ম্যানেজার ডিভাইসের সাথে প্রাপ্যতা ও শিফট সিঙ্ক করুন।"
