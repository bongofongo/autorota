    "help.section.history.example.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استعد مسودة سابقة: افتح سجل التحرير، وسّع حفظاً، وانقر استعادة لإرجاع الأسبوع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি পূর্বের খসড়া পুনরুদ্ধার করুন: সম্পাদনা লগ খুলুন, একটি সেভ প্রসারিত করুন এবং সপ্তাহটি ফিরিয়ে আনতে পুনরুদ্ধার ট্যাপ করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restore an earlier draft: open Edit Log, expand a save, and tap Restore to roll the week back."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restaura un borrador anterior: abre el Registro de Ediciones, expande una versión guardada y toca Restaurar para revertir la semana."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पुराना ड्राफ्ट पुनर्स्थापित करें: एडिट लॉग खोलें, सेव का विस्तार करें और सप्ताह को वापस लाने के लिए Restore पर टैप करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "恢复之前的草稿：打开编辑日志，展开某个保存项，点击恢复将该周回滚。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "復原先前的草稿：開啟編輯紀錄，展開某個保存項，點擊復原將該週回滾。"
          }
        }
      }
    },
    "help.section.history.example.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وسم الحفظات المهمة: انقر على حقل الوسم لحفظ معين لتمييزه بـ ‘Posted’ أو ‘Final’."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "গুরুত্বপূর্ণ সেভ লেবেল করুন: একটি সেভের ট্যাগ ফিল্ডে ট্যাপ করে এটিকে ‘Posted’ বা ‘Final’ হিসেবে চিহ্নিত করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Label important saves: tap a save’s tag field to mark it as ‘Posted’ or ‘Final’."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etiqueta versiones guardadas importantes: toca el campo de etiqueta de una versión para marcarla como ‘Publicada’ o ‘Final’."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "महत्वपूर्ण सेव्स को लेबल करें: किसी सेव के टैग फ़ील्ड पर टैप करके उसे ‘Posted’ या ‘Final’ के रूप में चिह्नित करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为重要保存项加标签：点击某个保存项的标签字段以将其标记为「已发布」或「最终」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為重要保存項加標籤：點擊某個保存項的標籤欄位以將其標記為「已發布」或「最終」。"
          }
        }
      }
    },
