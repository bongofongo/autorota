    "onboarding.page.ready.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف عضو الفريق الأول للبدء، ثم أنشئ المناوبات وقم بتوليد جدولك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "শুরু করতে আপনার প্রথম দলের সদস্য যোগ করুন, তারপর শিফট তৈরি করুন এবং আপনার রোস্টার জেনারেট করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add your first team member to get started, then create shifts and generate your rota."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade a tu primer miembro del equipo para empezar, luego crea turnos y genera tu horario."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "शुरू करने के लिए अपनी पहली टीम सदस्य जोड़ें, फिर शिफ्ट बनाएँ और अपना रोस्टर जेनरेट करें।"
          }
        },
