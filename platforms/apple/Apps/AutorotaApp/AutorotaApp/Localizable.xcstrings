        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সপ্তাহের মধ্যে যেতে তীর বোতাম ব্যবহার করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the arrow buttons to move between weeks."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa los botones de flecha para moverte entre semanas."
          }
