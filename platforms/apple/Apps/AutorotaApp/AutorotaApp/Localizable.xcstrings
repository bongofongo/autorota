            "value" : "এই কর্মচারী যে ভূমিকাগুলি কভার করতে পারেন সেগুলি বেছে নিন যাতে শিডিউলার শুধুমাত্র মিলে যাওয়া শিফটে তাদের বরাদ্দ করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick the roles this employee can cover so the scheduler only assigns them to matching shifts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige los roles que puede cubrir este empleado para que el programador solo le asigne turnos compatibles."
          }
