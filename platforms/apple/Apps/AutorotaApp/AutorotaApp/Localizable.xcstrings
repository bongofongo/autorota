    "tip.availability.mode.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتكرر التوفر الافتراضي كل أسبوع. بدّل إلى الفعلي لتجاوز التوفر لأسبوع واحد فقط."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ডিফল্ট প্রাপ্যতা প্রতি সপ্তাহে পুনরাবৃত্ত হয়। একটি একক সপ্তাহের জন্য প্রাপ্যতা ওভাররাইড করতে Actual-এ স্যুইচ করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Default availability repeats every week. Switch to Actual to override availability for a single week."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La disponibilidad predeterminada se repite cada semana. Cambia a Real para sobrescribirla solo una semana."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "डिफ़ॉल्ट उपलब्धता हर सप्ताह दोहराती है। एक ही सप्ताह के लिए उपलब्धता ओवरराइड करने हेतु Actual पर स्विच करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认可用性每周重复。切换到「实际」以覆盖单周的可用性。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "預設可用性每週重複。切換到「實際」以覆蓋單週的可用性。"
          }
        }
      }
    },
