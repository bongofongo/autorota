    "Previews the first employee's file. The export still produces one file per employee." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعرض معاينة لملف أول موظف. يستمر التصدير في إنتاج ملف لكل موظف."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রথম কর্মচারীর ফাইলের প্রিভিউ দেখায়। এক্সপোর্ট তবুও প্রতি কর্মচারীর জন্য একটি ফাইল তৈরি করে।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Previsualiza el archivo del primer empleado. La exportación sigue generando un archivo por empleado."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पहले कर्मचारी की फ़ाइल का पूर्वावलोकन दिखाता है। एक्सपोर्ट फिर भी प्रत्येक कर्मचारी के लिए एक फ़ाइल बनाता है।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "预览第一位员工的文件。导出仍会为每位员工生成一个文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "預覽第一位員工的檔案。匯出仍會為每位員工產生一個檔案。"
          }
        }
      }
    },
