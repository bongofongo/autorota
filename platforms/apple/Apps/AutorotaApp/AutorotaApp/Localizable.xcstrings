    "help.section.shifts.example.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مناوبة افتتاح الإثنين–الجمعة 6 صباحاً–2 ظهراً تتطلب 2 باريستا: اختر الإثنين–الجمعة، اضبط الأوقات، الدور = Barista، الحد الأقصى = 2."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সোম–শুক্র সকাল ৬টা–দুপুর ২টা ওপেনিং শিফট, ২ জন বারিস্তা প্রয়োজন: সোম–শুক্র নির্বাচন করুন, সময় সেট করুন, ভূমিকা = Barista, সর্বোচ্চ = ২।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opening shift Mon–Fri 6am–2pm requiring 2 baristas: pick Mon–Fri weekdays, set times, role = Barista, max = 2."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Turno de apertura lun–vie 6:00–14:00 con 2 baristas: selecciona lun–vie, ajusta las horas, rol = Barista, máx. = 2."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सोम–शुक्र सुबह 6 बजे–दोपहर 2 बजे ओपनिंग शिफ्ट, 2 बारिस्ता आवश्यक: सोम–शुक्र चुनें, समय निर्धारित करें, भूमिका = Barista, अधिकतम = 2।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "周一至周五 6:00–14:00 开店班次，需要 2 名 Barista：选择周一至周五，设定时间，角色 = Barista，最大值 = 2。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "週一至週五 6:00–14:00 開店班次，需要 2 名 Barista：選擇週一至週五，設定時間，角色 = Barista，最大值 = 2。"
          }
        }
      }
    },
    "help.section.shifts.example.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "غداء عطلة الأسبوع يحتاج 1–2 طهاة: اختر السبت/الأحد، الدور = المطبخ، الحد الأدنى = 1، الحد الأقصى = 2."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সপ্তাহান্তের ব্রাঞ্চে ১–২ জন রাঁধুনি প্রয়োজন: শনি/রবি নির্বাচন করুন, ভূমিকা = কিচেন, সর্বনিম্ন = ১, সর্বোচ্চ = ২।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weekend brunch needs 1–2 cooks: choose Sat/Sun, role = Kitchen, min = 1, max = 2."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El brunch del fin de semana necesita 1–2 cocineros: elige sáb./dom., rol = Cocina, mín. = 1, máx. = 2."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सप्ताहांत ब्रंच के लिए 1–2 रसोइए चाहिए: शनि/रवि चुनें, भूमिका = Kitchen, न्यूनतम = 1, अधिकतम = 2।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "周末早午餐需要 1–2 名厨师：选择周六/周日，角色 = 厨房，最小值 = 1，最大值 = 2。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
