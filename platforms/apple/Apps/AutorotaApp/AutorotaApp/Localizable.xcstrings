            "value" : "أنشئ جدول الأسبوع التالي: انتقل إلى الأسبوع التالي وانقر على إنشاء — يقوم المُجدوِل بتعبئة المناوبات باستخدام التوفر وميزانية الساعات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "পরবর্তী সপ্তাহের রোস্টার জেনারেট করুন: পরবর্তী সপ্তাহে যান এবং Generate ট্যাপ করুন — শিডিউলার প্রাপ্যতা ও ঘণ্টা বাজেট ব্যবহার করে শিফট পূরণ করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generate next week’s rota: navigate to next week and tap Generate — the scheduler fills shifts using availability and hour budgets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genera el horario de la próxima semana: ve a la próxima semana y toca Generar — el programador llena los turnos usando disponibilidad y presupuesto de horas."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अगले सप्ताह का रोस्टर जेनरेट करें: अगले सप्ताह पर जाएँ और Generate पर टैप करें — शेड्यूलर उपलब्धता और घंटा बजट का उपयोग करके शिफ्ट भरता है।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生成下周排班表：导航至下周并点击「生成」——排班器将利用可用性和工时预算填充班次。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "產生下週排班表：導覽至下週並點擊「產生」——排班器將利用可用性和工時預算填充班次。"
          }
        }
      }
    },
    "help.section.rota.example.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تبديل تعيين يدوياً: اضغط مطوّلاً على مناوبة معينة لنقل الموظف إلى مناوبة أخرى في نفس الأسبوع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ম্যানুয়ালি একটি অ্যাসাইনমেন্ট সোয়াপ করুন: বরাদ্দকৃত শিফটে দীর্ঘক্ষণ চাপ দিন যাতে কর্মচারীকে একই সপ্তাহের ভিন্ন শিফটে স্থানান্তর করা যায়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manually swap an assignment: long-press an assigned shift to move that employee to a different shift in the same week."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia manualmente una asignación: mantén pulsado un turno asignado para mover a ese empleado a otro turno de la misma semana."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी असाइनमेंट को मैन्युअल रूप से बदलें: किसी सौंपी गई शिफ्ट को लंबे समय तक दबाएँ ताकि उस कर्मचारी को उसी सप्ताह की किसी अन्य शिफ्ट में ले जाया जा सके।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "手动调换分配：长按已分配班次将该员工移至同一周的另一班次。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "手動調換分配：長按已分配班次將該員工移至同一週的另一班次。"
          }
        }
      }
    },
    "help.section.rota.item.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعرض الجدول الرئيسي أسبوعاً واحداً في كل مرة."
