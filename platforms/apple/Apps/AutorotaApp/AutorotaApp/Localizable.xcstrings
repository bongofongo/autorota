    "Adjusts availability, status, and chart colors so they remain distinguishable for the selected type of color vision.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يضبط ألوان التوفر والحالة والمخططات بحيث تبقى قابلة للتمييز وفق نوع رؤية الألوان المحدد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নির্বাচিত বর্ণদৃষ্টির জন্য পার্থক্য বজায় রাখতে উপলব্ধতা, স্ট্যাটাস ও চার্টের রং সমন্বয় করে।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta los colores de disponibilidad, estado y gráficos para que sigan siendo distinguibles según el tipo de visión de color seleccionado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उपलब्धता, स्थिति और चार्ट रंगों को समायोजित करता है ताकि चयनित रंग दृष्टि प्रकार के लिए वे पहचान में रहें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整可用时段、状态与图表颜色，使所选色觉类型下仍可清楚区分。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "調整可用時段、狀態與圖表顏色,讓所選色覺類型下仍能清楚區分。"
          }
        }
      }
    },
    "All availabilities set for next week": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تعيين جميع أوقات التوفر للأسبوع المقبل"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আগামী সপ্তাহের সব উপলব্ধতা সেট করা হয়েছে"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas las disponibilidades establecidas para la próxima semana"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगले सप्ताह की सभी उपलब्धताएँ सेट हो गईं"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已设置下周所有可用时段"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已設定下週所有可用時段"
          }
        }
      }
    },
    "All employees are already assigned to this shift.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جميع الموظفين مُعيَّنون بالفعل لهذه الوردية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সকল কর্মচারী ইতিমধ্যে এই শিফটে নিয়োগপ্রাপ্ত।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los empleados ya están asignados a este turno."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी कर्मचारी पहले से ही इस शिफ़्ट को सौंपे गए हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有员工均已分配至此班次。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "所有員工皆已指派至此班次。"
          }
        }
      }
    },
    "All shifts and assignments for this week will be permanently deleted.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم حذف جميع ورديات هذا الأسبوع وتعييناته نهائياً."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই সপ্তাহের সকল শিফট ও নিয়োগ স্থায়ীভাবে মুছে ফেলা হবে।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los turnos y asignaciones de esta semana se eliminarán permanentemente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस सप्ताह की सभी शिफ़्टें और असाइनमेंट स्थायी रूप से हटा दिए जाएँगे।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本周所有班次与分配将被永久删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本週所有班次與指派將被永久刪除。"
          }
        }
      }
    },
