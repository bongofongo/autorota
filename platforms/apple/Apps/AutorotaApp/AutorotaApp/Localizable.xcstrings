    "tip.employee.roles.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر الأدوار التي يمكن لهذا الموظف تغطيتها حتى يقوم المُجدوِل بتعيينه فقط للمناوبات المطابقة."
