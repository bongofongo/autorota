    "tip.rota.twopass.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعمل التوليد على مرحلتين: أولاً تغطية الأدوار المطلوبة، ثم تعبئة باقي الساعات للوصول إلى الساعات المستهدفة. راجع المساعدة → المُجدوِل لقواعد كسر التعادل."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "জেনারেট দুই ধাপে চলে: প্রথমে প্রয়োজনীয় ভূমিকা কভার করে, তারপর লক্ষ্য ঘণ্টা পর্যন্ত পূরণ করে। টাইব্রেক নিয়মাবলির জন্য Help → Scheduler দেখুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generate runs in two passes: first cover required roles, then top up to target hours. See Help → Scheduler for tie-break rules."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generar funciona en dos pasadas: primero cubre los roles requeridos y luego completa las horas hasta el objetivo. Consulta Ayuda → Programador para las reglas de desempate."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Generate दो पासों में चलता है: पहले आवश्यक भूमिकाओं को कवर करता है, फिर लक्ष्य घंटों तक भरता है। टाई-ब्रेक नियमों के लिए Help → Scheduler देखें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「生成」分两轮进行：首先覆盖必需角色，然后填充至目标工时。并列规则请参见「帮助 → 排班器」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「產生」分兩輪進行：首先覆蓋必需角色，然後填充至目標工時。並列規則請參見「說明 → 排班器」。"
          }
        }
      }
    },
