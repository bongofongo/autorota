    "Layout, profile, and cell content use your Export tab settings." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم التخطيط وملف التعريف ومحتوى الخلايا إعدادات تبويب التصدير الخاص بك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "লেআউট, প্রোফাইল ও সেল কনটেন্ট আপনার এক্সপোর্ট ট্যাব সেটিংস ব্যবহার করে।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El diseño, perfil y contenido de las celdas usan los ajustes de la pestaña Exportar."
