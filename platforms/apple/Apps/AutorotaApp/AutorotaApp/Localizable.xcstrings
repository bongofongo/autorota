    "license.modal.future_tier.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه الفئة غير متاحة بعد. سنعلمك عند إطلاقها — اهتمامك يساعدنا في تحديد الأولويات."
          }
