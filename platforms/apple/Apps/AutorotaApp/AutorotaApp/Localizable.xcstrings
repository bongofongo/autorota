          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia la disponibilidad de un empleado para un solo día."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी कर्मचारी की एक दिन की उपलब्धता बदलें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更改员工某一天的可用时段。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "變更員工某一天的可用時段。"
          }
        }
      }
    },
    "help.section.exceptions.item.4" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "للاستثناءات أولوية على الجدول المُولَّد تلقائياً."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ব্যতিক্রম স্বয়ংক্রিয়ভাবে তৈরি সময়সূচীর উপর অগ্রাধিকার পায়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exceptions take priority over the generated schedule."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las excepciones tienen prioridad sobre el horario generado."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपवाद उत्पन्न शेड्यूल पर प्राथमिकता लेते हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "例外的优先级高于自动生成的排班表。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "例外的優先順序高於自動產生的排班表。"
          }
        }
      }
    },
