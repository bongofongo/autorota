        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empleados"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कर्मचारी"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "员工"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "員工"
          }
        }
      }
    },
    "help.section.employees.item.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على زر + لإضافة موظف جديد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নতুন কর্মচারী যোগ করতে + বোতামে ট্যাপ করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the + button to add a new employee."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el botón + para añadir un nuevo empleado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नया कर्मचारी जोड़ने के लिए + बटन पर टैप करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击 + 按钮添加新员工。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點選 + 按鈕新增員工。"
          }
        }
      }
    },
    "help.section.employees.item.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدّد الاسم الأول واسم العائلة والاسم المستعار الاختياري."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "তাদের প্রথম নাম, শেষ নাম ও ঐচ্ছিক ডাকনাম সেট করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set their first name, last name, and optional nickname."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece su nombre, apellido y apodo opcional."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उनका पहला नाम, अंतिम नाम और वैकल्पिक उपनाम सेट करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置员工的名字、姓氏与可选的昵称。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定員工的名字、姓氏與選填的暱稱。"
          }
        }
      }
    },
    "help.section.employees.item.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عيّن دوراً واحداً أو أكثر (مثل: باريستا، مطبخ)."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এক বা একাধিক ভূমিকা নিযুক্ত করুন (যেমন বারিস্তা, রান্নাঘর)।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Assign one or more roles (e.g. Barista, Kitchen)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asigna uno o más roles (p. ej. Barista, Cocina)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक या अधिक भूमिकाएँ सौंपें (जैसे बारिस्ता, रसोई)।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分配一个或多个职位（如咖啡师、厨房）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "指派一個或多個職位(例如咖啡師、廚房)。"
          }
        }
      }
    },
    "help.section.employees.item.4": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدّد أجراً بالساعة وحدوداً أسبوعية للساعات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ঘণ্টা ভিত্তিক হার ও সাপ্তাহিক ঘণ্টার সীমা সেট করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set an hourly rate and weekly hour limits."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece un salario por hora y límites horarios semanales."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रति घंटा दर और साप्ताहिक घंटों की सीमा सेट करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置时薪与每周时数上限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定時薪與每週時數上限。"
          }
        }
      }
    },
    "help.section.employees.item.5": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدّد ساعات اليوم التي يكون متاحاً فيها للعمل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিটি দিনের কোন ঘণ্টায় তারা কাজের জন্য উপলব্ধ তা চিহ্নিত করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mark which hours of each day they are available to work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Marca qué horas de cada día están disponibles para trabajar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चिह्नित करें कि वे प्रत्येक दिन के किन घंटों में काम के लिए उपलब्ध हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标记每天可工作的时段。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "標記他們每天可工作的時段。"
          }
        }
      }
    },
    "help.section.employees.item.6": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على موظف لرؤية تفاصيله أو سجل ورديّاته."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "তাদের বিস্তারিত বা শিফট ইতিহাস দেখতে কোনো কর্মচারীতে ট্যাপ করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap an employee to see their details or shift history."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca un empleado para ver sus detalles o historial de turnos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कर्मचारी के विवरण या शिफ़्ट इतिहास को देखने के लिए उन पर टैप करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击员工以查看详细信息或班次历史。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點選員工以查看其詳細資訊或班次歷史。"
          }
        }
      }
    },
    "help.section.exceptions": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاستثناءات"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ব্যতিক্রম"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exceptions"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Excepciones"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपवाद"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例外"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "例外"
          }
        }
      }
    },
    "help.section.exceptions.item.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم الاستثناءات للتغييرات لمرة واحدة في تاريخ معين."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নির্দিষ্ট তারিখের একবার পরিবর্তনের জন্য ব্যতিক্রম ব্যবহার করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use exceptions for one-off changes to a specific date."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa excepciones para cambios puntuales en una fecha concreta."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी विशिष्ट तिथि के लिए एक बार के परिवर्तनों के लिए अपवादों का उपयोग करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对特定日期的一次性变更使用例外。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對特定日期的一次性變更使用例外。"
          }
        }
      }
    },
    "help.section.exceptions.item.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت موظفاً في وردية أو استبعده منها."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একজন কর্মচারীকে কোনো শিফটে স্থির করুন বা তাকে এর থেকে বাদ দিন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pin an employee to a shift or exclude them from one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fija a un empleado a un turno o exclúyelo de él."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी कर्मचारी को किसी शिफ़्ट के लिए तय करें या उसे शिफ़्ट से बाहर करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将员工固定于某班次或排除在外。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將員工固定於某班次或排除於外。"
          }
        }
      }
    },
    "help.section.exceptions.item.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غيّر توفر موظف ليوم واحد فقط."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একজন কর্মচারীর একটি দিনের উপলব্ধতা পরিবর্তন করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change an employee's availability for a single day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia la disponibilidad de un empleado para un solo día."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी कर्मचारी की एक दिन की उपलब्धता बदलें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更改员工某一天的可用时段。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "變更員工某一天的可用時段。"
          }
        }
      }
    },
    "help.section.exceptions.item.4": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "للاستثناءات أولوية على الجدول المُولَّد تلقائياً."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ব্যতিক্রম স্বয়ংক্রিয়ভাবে তৈরি সময়সূচীর উপর অগ্রাধিকার পায়।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exceptions take priority over the generated schedule."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las excepciones tienen prioridad sobre el horario generado."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपवाद उत्पन्न शेड्यूल पर प्राथमिकता लेते हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例外的优先级高于自动生成的排班表。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "例外的優先順序高於自動產生的排班表。"
          }
        }
      }
    },
    "help.section.exporting": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التصدير"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এক্সপোর্ট করা"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporting"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportar"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक्सपोर्ट करना"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯出"
          }
        }
      }
    },
    "help.section.exporting.item.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صدّر جدولك بصيغة CSV أو JSON من تبويب الجدول."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রোটা ট্যাব থেকে আপনার রোটা CSV বা JSON হিসেবে এক্সপোর্ট করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export your rota as CSV or JSON from the Rota tab."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta tu horario como CSV o JSON desde la pestaña Rota."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रोटा टैब से अपना रोटा CSV या JSON के रूप में एक्सपोर्ट करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从「排班表」标签页将排班表导出为 CSV 或 JSON。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從「排班表」分頁將排班表匯出為 CSV 或 JSON。"
          }
        }
      }
    },
    "help.section.exporting.item.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر تخطيطاً: حسب الموظف أو حسب الوردية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একটি লেআউট নির্বাচন করুন: কর্মচারী অনুযায়ী বা শিফট অনুযায়ী।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a layout: by employee or by shift."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un diseño: por empleado o por turno."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक लेआउट चुनें: कर्मचारी के अनुसार या शिफ़्ट के अनुसार।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择布局：按员工或按班次。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇版面:依員工或依班次。"
          }
        }
      }
    },
    "help.section.exporting.item.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضبط تفضيلات التصدير الافتراضية في إعدادات القائمة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "মেনু সেটিংসে আপনার ডিফল্ট এক্সপোর্ট পছন্দ সেট করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set your default export preferences in Menu settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura tus preferencias de exportación por defecto en los ajustes del Menú."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मेनू सेटिंग्स में अपनी डिफ़ॉल्ट एक्सपोर्ट प्राथमिकताएँ सेट करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在「菜单」设置中设置默认导出偏好。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「選單」設定中設定預設匯出偏好。"
          }
        }
      }
    },
