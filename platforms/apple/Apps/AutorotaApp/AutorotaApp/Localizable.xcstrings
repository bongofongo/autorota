    "license.tier.employee.description" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تطبيق مرافق للموظفين. مزامنة التوفر والمناوبات مع جهاز المدير المحلي للمدير."
