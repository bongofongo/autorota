    "onboarding.page.rota.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اعرض جدولك الأسبوعي وأدِره من تبويب الجدول. أنشئ الجداول تلقائياً ثم اضبطها حسب الحاجة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "রোস্টার ট্যাবে আপনার সাপ্তাহিক সময়সূচী দেখুন এবং পরিচালনা করুন। স্বয়ংক্রিয়ভাবে রোস্টার জেনারেট করুন, তারপর প্রয়োজন অনুযায়ী সামঞ্জস্য করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "View and manage your weekly schedule in the Rota tab. Generate rotas automatically, then adjust as needed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visualiza y gestiona tu horario semanal en la pestaña Horario. Genera horarios automáticamente y luego ajústalos según necesites."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "रोस्टर टैब में अपना साप्ताहिक शेड्यूल देखें और प्रबंधित करें। स्वचालित रूप से रोस्टर जेनरेट करें, फिर आवश्यकतानुसार समायोजित करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「排班表」标签页中查看和管理每周排班表。自动生成排班表，然后按需调整。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「排班表」標籤頁中檢視和管理每週排班表。自動產生排班表，然後依需求調整。"
          }
        }
      }
    },
