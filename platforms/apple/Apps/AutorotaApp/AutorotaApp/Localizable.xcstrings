    "help.section.scheduler.example.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اثنان من الباريستا متعادلان على مناوبة افتتاح — يفوز الأقرب إلى ساعاته المستهدفة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "দু'জন বারিস্তা একটি ওপেনিং শিফটে সমান — যিনি তার লক্ষ্য ঘণ্টার কাছাকাছি, তিনি জিতবেন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Two baristas tied for an opening shift — the one closer to their target hours wins."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dos baristas empatan por un turno de apertura — gana el que esté más cerca de sus horas objetivo."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "दो बारिस्ता एक ओपनिंग शिफ्ट के लिए बराबरी पर हैं — जो अपने लक्ष्य घंटों के करीब है, वह जीतेगा।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "两位 Barista 同时争取一个开店班次——离目标工时更近者获胜。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "兩位 Barista 同時爭取一個開店班次——離目標工時更近者獲勝。"
          }
        }
      }
    },
    "help.section.scheduler.example.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مايا حدّدت صباح الإثنين كـ \"ربما\" بدلاً من \"نعم\" — لن يتم اختيارها إلا إذا لم يتبقَّ باريستا متاح بـ \"نعم\"."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "মায়া সোমবার সকালে হ্যাঁ-এর পরিবর্তে হয়তো চিহ্নিত করেছেন — শুধুমাত্র তখনই তিনি নির্বাচিত হবেন যদি অন্য কোনো হ্যাঁ-প্রাপ্যতার বারিস্তা না থাকেন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya marked Monday morning as Maybe instead of Yes — she’ll only be picked if no Yes-availability barista is left."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya marcó el lunes por la mañana como Quizás en vez de Sí — solo se la elegirá si no queda ningún barista con disponibilidad Sí."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माया ने सोमवार सुबह को हाँ के बजाय शायद चिह्नित किया — उन्हें केवल तभी चुना जाएगा जब कोई हाँ-उपलब्धता वाला बारिस्ता न बचा हो।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya 将周一上午标记为「也许」而非「可」——只有在没有「可」可用的 Barista 时才会被选中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya 將週一上午標記為「也許」而非「可」——只有在沒有「可」可用的 Barista 時才會被選中。"
          }
        }
      }
    },
    "help.section.scheduler.item.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المرحلة 1 تغطي أولاً الدور المطلوب لكل مناوبة، من الأصعب إلى الأسهل."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "পাস ১ প্রথমে প্রতিটি শিফটের প্রয়োজনীয় ভূমিকা কভার করে, কঠিনতম থেকে সহজতর পর্যন্ত।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pass 1 covers each shift’s required role first, hardest-to-fill before easier roles."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La primera pasada cubre primero el rol requerido de cada turno, de los más difíciles a los más fáciles de cubrir."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पास 1 पहले प्रत्येक शिफ्ट की आवश्यक भूमिका को कवर करता है, सबसे कठिन से सबसे आसान तक।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "第一轮先按从最难到最易顺序覆盖每个班次所需角色。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "第一輪先按從最難到最易順序覆蓋每個班次所需角色。"
          }
        }
      }
    },
    "help.section.scheduler.item.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المرحلة 2 تملأ الفتحات المتبقية وفقاً لساعات العمل الأسبوعية المستهدفة لكل موظف."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "পাস ২ প্রতিটি কর্মচারীর লক্ষ্য সাপ্তাহিক ঘণ্টার দিকে অবশিষ্ট স্লট পূরণ করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pass 2 tops up remaining slots toward each employee’s target weekly hours."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La segunda pasada completa los huecos restantes hasta acercarse a las horas semanales objetivo de cada empleado."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पास 2 बचे हुए स्लॉट्स को प्रत्येक कर्मचारी के लक्ष्य साप्ताहिक घंटों की ओर भरता है।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "第二轮按每位员工的目标周工时填补剩余空缺。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "第二輪按每位員工的目標週工時填補剩餘空缺。"
          }
        }
      }
    },
    "help.section.scheduler.item.3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تفضّل قواعد كسر التعادل أصحاب الاستخدام الأقل لتُوزَّع الساعات بإنصاف."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "টাইব্রেকার কম ব্যবহারকে অগ্রাধিকার দেয় যাতে ঘণ্টা ন্যায্যভাবে বণ্টিত হয়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tie-breakers favor lower utilisation so hours are spread fairly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los criterios de desempate favorecen una utilización menor para repartir las horas con equidad."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "टाई-ब्रेकर कम उपयोग को प्राथमिकता देते हैं ताकि घंटे न्यायपूर्ण ढंग से बँटें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "并列时优先选择利用率较低者，以便公平分配工时。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "並列時優先選擇利用率較低者，以便公平分配工時。"
          }
        }
      }
    },
    "help.section.scheduler.item.4" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا تم تخطي موظف، تحقق من توفره لتلك الساعة، تطابق الدور، وحدود الساعات اليومية/الأسبوعية."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যদি কোনো কর্মচারী এড়িয়ে যাওয়া হয়, সেই ঘণ্টায় প্রাপ্যতা, ভূমিকা মিল এবং দৈনিক/সাপ্তাহিক ঘণ্টা সীমা পরীক্ষা করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If an employee was skipped, check availability for that hour, role match, and the daily/weekly hour caps."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si se omite a un empleado, comprueba su disponibilidad para esa hora, la coincidencia de rol y los límites de horas diarios/semanales."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि कोई कर्मचारी छूट गया, तो उस समय उपलब्धता, भूमिका मेल और दैनिक/साप्ताहिक घंटा सीमा जाँचें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果某员工被跳过，请检查该时段可用性、角色匹配以及每日/每周工时上限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果某員工被跳過，請檢查該時段可用性、角色匹配以及每日/每週工時上限。"
          }
        }
      }
    },
