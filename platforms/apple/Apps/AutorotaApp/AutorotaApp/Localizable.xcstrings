    "Generates PDF, ICS calendar, Markdown summary, and XLSX spreadsheet using your Export tab Employee View settings." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُنشئ ملف PDF وتقويم ICS وملخّص Markdown وجدول XLSX باستخدام إعدادات «عرض الموظف» في تبويب التصدير."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার এক্সপোর্ট ট্যাবের কর্মচারী ভিউ সেটিংস ব্যবহার করে PDF, ICS ক্যালেন্ডার, Markdown সারাংশ ও XLSX স্প্রেডশিট তৈরি করে।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genera PDF, calendario ICS, resumen en Markdown y hoja XLSX usando los ajustes de Vista por Empleado de la pestaña Exportar."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी एक्सपोर्ट टैब की कर्मचारी दृश्य सेटिंग्स का उपयोग करके PDF, ICS कैलेंडर, Markdown सारांश और XLSX स्प्रेडशीट बनाता है।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "依据您「导出」标签页的员工视图设置，生成 PDF、ICS 日历、Markdown 摘要与 XLSX 电子表格。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "依您「匯出」分頁的員工檢視設定,產生 PDF、ICS 日曆、Markdown 摘要與 XLSX 試算表。"
          }
        }
      }
    },
