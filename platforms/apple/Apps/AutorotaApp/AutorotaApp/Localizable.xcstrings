    "license.tier.saas.description" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اشتراك مدعوم بالويب. متعدد الأجهزة والمواقع، تعاون فوري مع نسخ احتياطية وتقارير."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ওয়েব-ভিত্তিক সাবস্ক্রিপশন। একাধিক ডিভাইস ও স্থান, রিয়েল-টাইম টিম সহযোগিতা, ব্যাকআপ ও রিপোর্টিংসহ।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Web-backed subscription. Multi-device, multi-location, real-time team collaboration with backups and reporting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suscripción en la nube. Multi-dispositivo, multi-sede, colaboración en tiempo real con copias e informes."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वेब-आधारित सदस्यता। मल्टी-डिवाइस, मल्टी-लोकेशन, बैकअप व रिपोर्टिंग के साथ रीयल-टाइम टीम सहयोग।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "基于网络的订阅。多设备、多地点,实时团队协作,带备份和报告。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "網路訂閱服務。多裝置、多地點,即時團隊協作,含備份與報告。"
          }
        }
