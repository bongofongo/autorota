    "help.section.history.item.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعرض سجلاً لجميع تغييرات الجدول المحفوظة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সব সংরক্ষিত সময়সূচী পরিবর্তনের লগ দেখুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View a log of all saved schedule changes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consulta el registro de todos los cambios guardados del horario."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सहेजे गए सभी शेड्यूल परिवर्तनों का लॉग देखें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看所有已保存排班变更的记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "檢視所有已儲存排班變更的紀錄。"
          }
        }
      }
    },
    "help.section.history.item.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعرف ما الذي تغيّر ومتى."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কী পরিবর্তন হয়েছে এবং কখন হয়েছে দেখুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See what was changed and when."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira qué se cambió y cuándo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देखें क्या और कब बदला गया।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看变更内容与时间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看變更內容與時間。"
          }
        }
      }
    },
    "help.section.history.item.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مفيد لتتبع التعديلات بمرور الوقت."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সময়ের সাথে সম্পাদনা ট্র্যাক করতে কার্যকর।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Useful for tracking edits over time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Útil para hacer seguimiento de las ediciones a lo largo del tiempo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "समय के साथ संपादनों को ट्रैक करने के लिए उपयोगी।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "适合追踪一段时间内的编辑。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "適合追蹤一段時間內的編輯。"
          }
        }
      }
    },
    "help.section.rota": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الجدول"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রোটা"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rota"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rota"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रोटा"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "排班表"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "排班表"
          }
        }
      }
    },
    "help.section.rota.item.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعرض الجدول الرئيسي أسبوعاً واحداً في كل مرة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রধান সময়সূচী ভিউ একসাথে এক সপ্তাহ দেখায়।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The main schedule view shows one week at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La vista principal del horario muestra una semana a la vez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुख्य शेड्यूल दृश्य एक बार में एक सप्ताह दिखाता है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主排班视图一次显示一周。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "主排班檢視一次顯示一週。"
          }
        }
      }
    },
    "help.section.rota.item.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم أزرار الأسهم للتنقل بين الأسابيع."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সপ্তাহের মধ্যে যেতে তীর বোতাম ব্যবহার করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the arrow buttons to move between weeks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa los botones de flecha para moverte entre semanas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हफ़्तों के बीच जाने के लिए तीर बटन का उपयोग करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用箭头按钮在周次之间切换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用箭頭按鈕在週次之間切換。"
          }
        }
      }
    },
    "help.section.rota.item.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على «توليد» لتعيين الموظفين تلقائياً للورديات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কর্মচারীদের স্বয়ংক্রিয়ভাবে শিফটে নিয়োগ করতে জেনারেট ট্যাপ করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Generate to automatically assign employees to shifts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca Generar para asignar empleados a turnos automáticamente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कर्मचारियों को शिफ़्टों में स्वचालित रूप से असाइन करने के लिए जनरेट पर टैप करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击「生成」自动将员工分配到班次。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點選「產生」自動將員工指派到班次。"
          }
        }
      }
    },
    "help.section.rota.item.4": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على أي تعيين لتغييره يدوياً."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ম্যানুয়ালি পরিবর্তন করতে কোনো নিয়োগে ট্যাপ করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap any assignment to change it manually."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca cualquier asignación para cambiarla manualmente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैन्युअल रूप से बदलने के लिए किसी भी असाइनमेंट पर टैप करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击任一分配以手动更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點選任一指派以手動變更。"
          }
        }
      }
    },
    "help.section.rota.item.5": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أكّد الورديات عندما تكون راضياً عن الجدول."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সময়সূচীতে সন্তুষ্ট হলে শিফট নিশ্চিত করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Confirm shifts when you are happy with the schedule."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Confirma los turnos cuando estés conforme con el horario."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप शेड्यूल से संतुष्ट हों, तो शिफ़्ट की पुष्टि करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对排班满意时请确认班次。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對排班滿意時請確認班次。"
          }
        }
      }
    },
    "help.section.settings": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإعدادات"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সেটিংস"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustes"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेटिंग्स"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定"
          }
        }
      }
    },
    "help.section.settings.item.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غيّر سمة التطبيق إلى فاتحة أو داكنة أو حسب النظام."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাপ থিম পরিবর্তন করুন—হালকা, গাঢ় বা সিস্টেম।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change the app theme to Light, Dark, or System."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia el tema de la app a Claro, Oscuro o Sistema."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप थीम को लाइट, डार्क या सिस्टम में बदलें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将应用主题切换为浅色、深色或系统。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將應用程式主題切換為淺色、深色或系統。"
          }
        }
      }
    },
    "help.section.settings.item.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضبط العملة المفضلة للأجور بالساعة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ঘণ্টা ভিত্তিক হারের জন্য আপনার পছন্দনীয় মুদ্রা সেট করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set your preferred currency for hourly rates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece tu moneda preferida para los salarios por hora."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रति घंटा दरों के लिए अपनी पसंदीदा मुद्रा सेट करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置时薪偏好的货币。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定時薪偏好的貨幣。"
          }
        }
      }
    },
    "help.section.settings.item.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خصّص التبويبات التي تظهر في شريط التبويبات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার ট্যাব বারে কোন ট্যাবগুলি দেখা যাবে তা কাস্টমাইজ করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Customise which tabs appear in your tab bar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Personaliza qué pestañas aparecen en la barra."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कस्टमाइज़ करें कि आपके टैब बार में कौन से टैब दिखाई दें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自定义标签栏上显示的标签。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自訂分頁列上顯示的分頁。"
          }
        }
      }
    },
    "help.section.settings.item.4": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُبقي مزامنة iCloud بياناتك محدَّثة عبر أجهزتك."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Sync আপনার ডিভাইসগুলিতে আপনার তথ্য আপ-টু-ডেট রাখে।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Sync keeps your data up to date across devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Sync mantiene tus datos al día en todos tus dispositivos."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Sync आपके डेटा को सभी डिवाइसों में अद्यतन रखता है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 同步会让您的数据在各设备间保持最新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 同步會讓您的資料在各裝置間保持最新。"
          }
        }
      }
    },
    "help.section.shifts": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الورديات"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শিফট"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shifts"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Turnos"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शिफ़्टें"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "班次"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "班次"
          }
        }
      }
    },
    "help.section.shifts.item.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحدّد الورديات الفترات التي تجدولها كل أسبوع."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শিফট প্রতি সপ্তাহে আপনার সময়সূচীর স্লট সংজ্ঞায়িত করে।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shifts define the slots you schedule each week."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los turnos definen los espacios que programas cada semana."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शिफ़्टें उन स्लॉट्स को परिभाषित करती हैं जिन्हें आप हर सप्ताह शेड्यूल करते हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "班次定义每周要排的时段。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "班次定義每週要排的時段。"
          }
        }
      }
    },
    "help.section.shifts.item.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدّد الاسم ووقت البداية والنهاية واليوم من الأسبوع."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নাম, শুরুর সময়, শেষ সময় ও সপ্তাহের দিন সেট করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set a name, start time, end time, and day of the week."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece nombre, hora de inicio, hora de fin y día de la semana."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नाम, प्रारंभ समय, समाप्ति समय और सप्ताह का दिन सेट करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置名称、开始时间、结束时间与星期几。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定名稱、開始時間、結束時間與星期幾。"
          }
        }
      }
    },
    "help.section.shifts.item.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر الأدوار المطلوبة وعدد الموظفين."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কোন ভূমিকা প্রয়োজন এবং কতজন কর্মী চয়ন করুন।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which roles are needed and how many staff."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué roles se necesitan y cuánto personal."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि कौन सी भूमिकाएँ चाहिए और कितने कर्मचारी।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择所需的职位以及人员数量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇所需的職位以及人員數量。"
          }
        }
      }
    },
    "help.section.shifts.item.4": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُعاد استخدام الورديات في كل مرة تولّد فيها جدولاً."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিবার রোটা জেনারেট করার সময় শিফট পুনরায় ব্যবহৃত হয়।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shifts are reused every time you generate a rota."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los turnos se reutilizan cada vez que generas un horario."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर बार जब आप रोटा जनरेट करते हैं तो शिफ़्टें पुनः उपयोग की जाती हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每次生成排班表时都会重复使用班次。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每次產生排班表時都會重複使用班次。"
          }
        }
      }
    },
    "help.step.1": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف موظفيك وأدوارهم"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার কর্মচারী ও তাদের ভূমিকা যোগ করুন"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add your employees and their roles"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade tus empleados y sus roles"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने कर्मचारी और उनकी भूमिकाएँ जोड़ें"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加员工及其职位"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增員工及其職位"
          }
        }
      }
    },
    "help.step.2": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ ورديات لكل يوم"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিটি দিনের জন্য শিফট তৈরি করুন"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create shifts for each day"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea turnos para cada día"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रत्येक दिन के लिए शिफ़्टें बनाएँ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为每天创建班次"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為每天建立班次"
          }
        }
      }
    },
    "help.step.3": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ولّد جدولاً لأي أسبوع"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "যেকোনো সপ্তাহের জন্য রোটা জেনারেট করুন"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Generate a rota for any week"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Genera un horario para cualquier semana"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी सप्ताह के लिए रोटा जनरेट करें"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为任何一周生成排班表"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為任何一週產生排班表"
          }
        }
      }
    },
