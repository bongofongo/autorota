    "help.section.settings.item.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "غيّر سمة التطبيق إلى فاتحة أو داكنة أو حسب النظام."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "অ্যাপ থিম পরিবর্তন করুন—হালকা, গাঢ় বা সিস্টেম।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change the app theme to Light, Dark, or System."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia el tema de la app a Claro, Oscuro o Sistema."
          }
