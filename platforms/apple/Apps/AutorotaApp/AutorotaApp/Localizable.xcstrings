    "Send each employee a markdown rota via their preferred channel (iMessage, WhatsApp, or Email). Skipped recipients are listed after." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أرسل لكل موظف جدول Markdown عبر قناته المفضلة (iMessage أو WhatsApp أو البريد الإلكتروني). يُسرد المستلمون الذين تم تخطّيهم بعد ذلك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিটি কর্মচারীকে তাদের পছন্দনীয় চ্যানেলে (iMessage, WhatsApp, বা ইমেইল) Markdown রোটা পাঠান। এড়িয়ে যাওয়া প্রাপকগণ পরে তালিকাভুক্ত।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Envía a cada empleado un horario en Markdown por su canal preferido (iMessage, WhatsApp o correo). Los destinatarios omitidos se listan a continuación."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रत्येक कर्मचारी को उनके पसंदीदा चैनल (iMessage, WhatsApp, या ईमेल) से Markdown रोटा भेजें। छोड़े गए प्राप्तकर्ता बाद में सूचीबद्ध हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通过每位员工偏好的渠道（iMessage、WhatsApp 或电子邮件）发送 Markdown 排班表。被跳过的收件人会列在其后。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "透過每位員工偏好的管道(iMessage、WhatsApp 或電子郵件)傳送 Markdown 排班表。略過的收件人會列於其後。"
          }
        }
      }
    },
