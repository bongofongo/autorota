    "settings.language.restart_note": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن تتحدث بعض النصوص بالكامل إلا بعد إعادة تشغيل التطبيق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কিছু লেখা সম্পূর্ণরূপে আপডেট হবে শুধুমাত্র অ্যাপ পুনরায় চালু করার পরে।"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some text will only update fully after restarting the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algún texto solo se actualizará por completo después de reiniciar la app."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ पाठ केवल ऐप को पुनः प्रारंभ करने के बाद ही पूरी तरह अद्यतन होगा।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部分文字需要重新启动应用后才会完全更新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "部分文字需要重新啟動應用程式才會完全更新。"
          }
        }
      }
    },
