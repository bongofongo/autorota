    },
    "This employee will be removed from future rotas. Past and current assignments are preserved.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتم إزالة هذا الموظف من الجداول المستقبلية. تُحفَظ التعيينات السابقة والحالية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই কর্মচারীকে ভবিষ্যতের রোটা থেকে সরানো হবে। অতীত ও বর্তমান নিয়োগ সংরক্ষিত থাকবে।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este empleado se quitará de futuros horarios. Las asignaciones pasadas y actuales se conservan."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस कर्मचारी को भविष्य के रोटा से हटा दिया जाएगा। पिछले और वर्तमान असाइनमेंट सुरक्षित रहेंगे।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此员工将从未来的排班表中移除。过去与当前的分配将保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此員工將從未來的排班表中移除。過去與目前的指派會保留。"
          }
        }
      }
    },
    "This exception covers %lld days (more than %lld weeks). Long ranges can be hard to manage — are you sure?": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشمل هذا الاستثناء %1$lld يوماً (أكثر من %2$lld أسابيع). قد يصعب إدارة النطاقات الطويلة — هل أنت متأكد؟"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই ব্যতিক্রম %1$lld দিন কভার করে (%2$lld সপ্তাহের বেশি)। দীর্ঘ পরিসর পরিচালনা কঠিন হতে পারে — আপনি কি নিশ্চিত?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "This exception covers %1$lld days (more than %2$lld weeks). Long ranges can be hard to manage — are you sure?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta excepción cubre %1$lld días (más de %2$lld semanas). Los rangos largos pueden ser difíciles de gestionar, ¿estás seguro?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह अपवाद %1$lld दिनों को कवर करता है (%2$lld सप्ताह से अधिक)। लंबी श्रेणियों का प्रबंधन कठिन हो सकता है — क्या आप निश्चित हैं?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此例外覆盖 %1$lld 天（超过 %2$lld 周）。长范围可能难以管理—确定吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此例外涵蓋 %1$lld 天(超過 %2$lld 週)。長範圍可能難以管理—您確定嗎?"
          }
        }
      }
    },
    "This exception will be removed. The employee's default availability applies on that date.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتم إزالة هذا الاستثناء. سيُطبَّق توفر الموظف الافتراضي في ذلك التاريخ."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই ব্যতিক্রম সরানো হবে। সেই তারিখে কর্মচারীর ডিফল্ট উপলব্ধতা প্রযোজ্য হবে।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta excepción se eliminará. La disponibilidad por defecto del empleado se aplicará en esa fecha."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह अपवाद हटा दिया जाएगा। उस तिथि पर कर्मचारी की डिफ़ॉल्ट उपलब्धता लागू होगी।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此例外将被移除。该日期将使用员工的默认可用时段。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此例外將被移除。該日期將套用員工的預設可用時段。"
          }
        }
      }
    },
    "This rota has unsaved changes. The version that gets sent should match the saved snapshot.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتوي هذا الجدول على تغييرات غير محفوظة. يجب أن تتطابق النسخة المُرسَلة مع اللقطة المحفوظة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই রোটায় অসংরক্ষিত পরিবর্তন রয়েছে। যে সংস্করণ পাঠানো হবে তা সংরক্ষিত স্ন্যাপশটের সাথে মেলা উচিত।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este horario tiene cambios sin guardar. La versión que se envíe debería coincidir con la instantánea guardada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस रोटा में बिना सहेजे परिवर्तन हैं। भेजी जाने वाली प्रति को सहेजे गए स्नैपशॉट से मेल खाना चाहिए।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此排班表有未保存的更改。发送的版本应与已保存的快照一致。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此排班表有尚未儲存的變更。傳送的版本應與已儲存的快照一致。"
          }
        }
      }
    },
    "This rota is from a past week. Are you sure you want to make changes?": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الجدول من أسبوع سابق. هل أنت متأكد من إجراء تغييرات؟"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই রোটা একটি অতীত সপ্তাহের। আপনি কি নিশ্চিত যে পরিবর্তন করতে চান?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este horario es de una semana pasada. ¿Seguro que quieres hacer cambios?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह रोटा एक पिछले सप्ताह का है। क्या आप वाकई परिवर्तन करना चाहते हैं?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此排班表为过去的某周。确定要进行变更吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此排班表為過去週次。您確定要進行變更嗎?"
          }
        }
      }
    },
    "This shift and all its assignments will be permanently deleted.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم حذف هذه الوردية وجميع تعييناتها نهائياً."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই শিফট এবং এর সব নিয়োগ স্থায়ীভাবে মুছে ফেলা হবে।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este turno y todas sus asignaciones se eliminarán permanentemente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह शिफ़्ट और इसके सभी असाइनमेंट स्थायी रूप से हटा दिए जाएँगे।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此班次及其所有分配将被永久删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此班次及其所有指派將被永久刪除。"
          }
        }
      }
    },
    "This week": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الأسبوع"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই সপ্তাহ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta semana"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस सप्ताह"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本周"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本週"
          }
        }
      }
    },
    "This will overwrite the current schedule for week of %@ with the state from this save. This cannot be undone.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى الكتابة فوق الجدول الحالي لأسبوع %@ بالحالة من هذا الحفظ. لا يمكن التراجع."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি %@ সপ্তাহের বর্তমান সময়সূচীকে এই সেভের অবস্থা দিয়ে প্রতিস্থাপন করবে। এটি পূর্বাবস্থায় ফেরানো যাবে না।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto sobrescribirá el horario actual de la semana del %@ con el estado de este guardado. No se puede deshacer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह %@ सप्ताह के मौजूदा शेड्यूल को इस सेव की स्थिति से अधिलेखित कर देगा। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会用本次保存的状态覆盖 %@ 那周的当前排班表。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會以此次儲存的狀態覆寫 %@ 那週的目前排班表。此操作無法復原。"
          }
        }
      }
    },
