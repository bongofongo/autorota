          "stringUnit" : {
            "state" : "translated",
            "value" : "Envía el horario del personal por correo en PDF: elige formato PDF, perfil = Horario del Personal y compártelo desde la hoja del sistema."
          }
        },
        "hi" : {
          "stringUnit" : {
