        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस कर्मचारी द्वारा कवर की जा सकने वाली भूमिकाएँ चुनें ताकि शेड्यूलर उन्हें केवल मेल खाती शिफ्टों पर असाइन करे।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择此员工可担任的角色，以便排班器只将其分配到匹配的班次。"
