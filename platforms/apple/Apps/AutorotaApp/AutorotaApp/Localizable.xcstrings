    "license.trial.expired.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتهت تجربتك المجانية. لا يزال بإمكانك عرض البيانات وتصديرها، لكن التعديلات الجديدة متوقفة حتى الشراء."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার বিনামূল্যের ট্রায়াল শেষ হয়েছে। আপনি এখনও ডেটা দেখতে ও এক্সপোর্ট করতে পারেন, তবে কেনার আগে নতুন এডিট স্থগিত।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your free trial has ended. You can still view and export your data, but new edits are paused until you purchase."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu prueba gratuita ha finalizado. Puedes seguir viendo y exportando datos, pero las ediciones están pausadas hasta la compra."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका मुफ़्त ट्रायल समाप्त हो गया है। आप अभी भी डेटा देख और निर्यात कर सकते हैं, लेकिन खरीद तक नए संपादन रोक दिए गए हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "免费试用已结束。您仍可查看和导出数据,但购买前无法新建编辑。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "免費試用已結束。您仍可檢視和匯出資料,但購買前暫停新增編輯。"
          }
        }
      }
    },
