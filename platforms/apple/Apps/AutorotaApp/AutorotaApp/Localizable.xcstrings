    "All employees are already assigned to this shift." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جميع الموظفين مُعيَّنون بالفعل لهذه الوردية."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সকল কর্মচারী ইতিমধ্যে এই শিফটে নিয়োগপ্রাপ্ত।"
          }
