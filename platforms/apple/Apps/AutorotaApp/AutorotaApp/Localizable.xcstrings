    "help.section.rota.item.5" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أكّد الورديات عندما تكون راضياً عن الجدول."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সময়সূচীতে সন্তুষ্ট হলে শিফট নিশ্চিত করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirm shifts when you are happy with the schedule."
          }
        },
        "es" : {
          "stringUnit" : {
