          "stringUnit" : {
            "state" : "translated",
            "value" : "ऐप थीम को लाइट, डार्क या सिस्टम में बदलें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将应用主题切换为浅色、深色或系统。"
