    "onboarding.page.tier_pick.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر الخيار الذي يناسب طريقة استخدامك لـ Autorota. يمكنك التغيير لاحقاً من الإعدادات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorota কীভাবে ব্যবহার করবেন তার সাথে মানানসই অপশন বেছে নিন। পরে সেটিংসে পরিবর্তন করতে পারবেন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick the option that fits how you'll use Autorota. You can change later in Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige la opción que mejor se adapte a tu uso de Autorota. Puedes cambiarla luego en Ajustes."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वह विकल्प चुनें जो आपके Autorota उपयोग के तरीक़े के अनुकूल हो। बाद में सेटिंग्स में बदल सकते हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择适合您使用 Autorota 方式的选项。之后可在设置中更改。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選擇符合您使用 Autorota 方式的選項。之後可在設定中變更。"
          }
        }
      }
    },
