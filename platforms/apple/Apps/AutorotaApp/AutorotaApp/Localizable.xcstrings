        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই টিয়ার এখনও উপলব্ধ নয়। প্রকাশের সময় আপনাকে জানাবো — আপনার আগ্রহ অগ্রাধিকার নির্ধারণে সাহায্য করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This tier isn't available yet. We'll let you know when it ships — your interest helps us prioritise."
