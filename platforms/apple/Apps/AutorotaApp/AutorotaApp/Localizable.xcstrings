            "state": "translated",
            "value": "এখানে বিশ্লেষণ দেখতে কিছু শিফট সময়সূচী করুন।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Programa algunos turnos para ver análisis aquí."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहाँ एनालिटिक्स देखने के लिए कुछ शिफ़्ट शेड्यूल करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安排一些班次后，这里会显示数据分析。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "安排一些班次後,這裡會顯示數據分析。"
