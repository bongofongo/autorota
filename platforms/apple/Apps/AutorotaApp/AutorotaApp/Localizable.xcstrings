    "Applied" : {

    },
    "Applied when exporting per-employee schedules, whether for all employees or a single one. Wage and cost data are never included." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُطبَّق عند تصدير جداول حسب الموظف، سواء لجميع الموظفين أو لموظف واحد. لا تُدرج بيانات الأجور والتكاليف أبداً."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতি কর্মচারীর সময়সূচী এক্সপোর্ট করার সময় প্রযোজ্য, সকল কর্মচারীর জন্য হোক বা একজনের জন্য। মজুরি ও খরচের তথ্য কখনো অন্তর্ভুক্ত করা হয় না।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se aplica al exportar horarios por empleado, ya sea para todos o para uno solo. Los datos de salario y coste nunca se incluyen."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रत्येक कर्मचारी के शेड्यूल को एक्सपोर्ट करते समय लागू, चाहे सभी कर्मचारियों के लिए हो या एक के लिए। वेतन और लागत डेटा कभी शामिल नहीं किया जाता।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "导出按员工划分的排班表时应用，无论是所有员工或单个员工。永远不会包含工资与成本数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "匯出個別員工班表時套用,無論是所有員工或單一員工。永遠不會包含薪資與成本資料。"
          }
        }
      }
    },
    "Applied when exporting the whole rota as one file." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُطبَّق عند تصدير الجدول كاملاً كملف واحد."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "পুরো রোটাকে একটি ফাইল হিসেবে এক্সপোর্ট করার সময় প্রযোজ্য।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se aplica al exportar todo el horario como un único archivo."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पूरे रोटा को एक फ़ाइल के रूप में एक्सपोर्ट करते समय लागू।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将整份排班表导出为单一文件时应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將整份排班表匯出為單一檔案時套用。"
          }
        }
      }
    },
