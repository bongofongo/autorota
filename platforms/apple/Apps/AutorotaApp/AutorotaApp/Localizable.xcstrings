    "tip.editlog.restore.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر استعادة على أي حفظ لإرجاع الأسبوع إلى تلك اللقطة. يصبح الوضع الحالي حفظاً جديداً أولاً."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "যেকোনো সেভে Restore ট্যাপ করে সপ্তাহটি সেই স্ন্যাপশটে ফিরিয়ে আনুন। বর্তমান অবস্থা প্রথমে একটি নতুন সেভে পরিণত হয়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap Restore on any save to roll the week back to that snapshot. Current state becomes a new save first."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca Restaurar en cualquier versión guardada para revertir la semana a esa instantánea. El estado actual se guarda primero como una nueva versión."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी भी सेव पर Restore टैप करके सप्ताह को उस स्नैपशॉट पर वापस ले जाएँ। पहले वर्तमान स्थिति एक नई सेव बन जाती है।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击任意保存项的「恢复」以将该周回滚到此快照。当前状态会先成为新的保存项。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點擊任意保存項的「復原」以將該週回滾到此快照。目前狀態會先成為新的保存項。"
          }
        }
      }
    },
