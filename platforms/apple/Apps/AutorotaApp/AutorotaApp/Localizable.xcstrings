    "help.section.employees.example.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعمل مايا من الإثنين إلى الجمعة من 6 صباحاً حتى 2 ظهراً: انقر على كل يوم في شبكة التوفر واسحب عبر الساعات 6–14 لتمييزها بالأخضر."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "মায়া সোম–শুক্র সকাল ৬টা–দুপুর ২টা কাজ করেন: প্রাপ্যতার গ্রিডে প্রতিটি কর্মদিবসে ট্যাপ করুন এবং ৬–১৪ ঘণ্টা জুড়ে টানুন যাতে সেগুলি সবুজ চিহ্নিত হয়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya works Mon–Fri 6am–2pm: tap each weekday in the availability grid and drag across hours 6–14 to mark them green."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya trabaja de lunes a viernes de 6:00 a 14:00: toca cada día laborable en la cuadrícula de disponibilidad y arrastra por las horas 6–14 para marcarlas en verde."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माया सोम–शुक्र सुबह 6 बजे से दोपहर 2 बजे तक काम करती हैं: उपलब्धता ग्रिड में प्रत्येक कार्यदिवस पर टैप करें और घंटे 6–14 पर खींचकर उन्हें हरा चिह्नित करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya 周一至周五早上 6 点到下午 2 点工作：在可用性网格中点击每个工作日，然后拖动 6–14 时段标记为绿色。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya 週一至週五早上 6 點到下午 2 點工作：在可用性網格中點選每個工作日，然後拖動 6–14 時段標記為綠色。"
          }
        }
      }
    },
    "help.section.employees.example.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أوقات بعد الظهر للطلاب فقط: استخدم مستطيل السحب على شبكة التوفر لوضع علامة \"نعم\" على الأربعاء من 2 ظهراً حتى 8 مساءً بحركة واحدة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "শুধুমাত্র শিক্ষার্থীদের বিকেল: প্রাপ্যতার গ্রিডে ড্র্যাগ-আয়তক্ষেত্র ব্যবহার করে এক অঙ্গভঙ্গিতে বুধবার দুপুর ২টা–রাত ৮টা \"হ্যাঁ\" চিহ্নিত করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Student-only afternoons: use the drag-rectangle on the availability grid to mark Wednesday 2pm–8pm as Yes in one gesture."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tardes solo para estudiantes: usa el rectángulo de arrastre en la cuadrícula de disponibilidad para marcar el miércoles de 14:00 a 20:00 como Sí en un solo gesto."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "केवल छात्रों की दोपहर: एक ही जेस्चर में बुधवार 2 बजे–8 बजे को हाँ चिह्नित करने के लिए उपलब्धता ग्रिड पर ड्रैग-रेक्टैंगल का उपयोग करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅学生下午：在可用性网格上使用拖拽矩形，一次手势将周三下午 2 点至 8 点标记为「可」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅學生下午：在可用性網格上使用拖曳矩形，一次手勢將週三下午 2 點至 8 點標記為「可」。"
          }
        }
      }
    },
    "help.section.employees.example.3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دوران: فعّل مفتاحي Barista و Shift Lead حتى يصبح الموظف مؤهلاً لأي من نوعي المناوبة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "দুটি ভূমিকা: বারিস্তা এবং শিফট লিড টগল সক্ষম করুন যাতে কর্মচারী উভয় ধরনের শিফটের জন্য যোগ্য হন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Two roles: enable Barista and Shift Lead toggles so the employee qualifies for either type of shift."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dos roles: activa los interruptores de Barista y Encargado de Turno para que el empleado pueda cubrir cualquiera de los dos tipos de turno."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "दो भूमिकाएँ: Barista और Shift Lead टॉगल सक्षम करें ताकि कर्मचारी किसी भी प्रकार की शिफ्ट के लिए योग्य हो।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "两个角色：启用 Barista 和班次组长开关，使该员工可担任两类班次。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "兩個角色：啟用 Barista 和班次組長開關，使該員工可擔任兩類班次。"
          }
        }
      }
    },
    "help.section.employees.item.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على زر + لإضافة موظف جديد."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নতুন কর্মচারী যোগ করতে + বোতামে ট্যাপ করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the + button to add a new employee."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca el botón + para añadir un nuevo empleado."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नया कर्मचारी जोड़ने के लिए + बटन पर टैप करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击 + 按钮添加新员工。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點選 + 按鈕新增員工。"
          }
        }
      }
    },
    "help.section.employees.item.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد الاسم الأول واسم العائلة والاسم المستعار الاختياري."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "তাদের প্রথম নাম, শেষ নাম ও ঐচ্ছিক ডাকনাম সেট করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set their first name, last name, and optional nickname."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece su nombre, apellido y apodo opcional."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उनका पहला नाम, अंतिम नाम और वैकल्पिक उपनाम सेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置员工的名字、姓氏与可选的昵称。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定員工的名字、姓氏與選填的暱稱。"
          }
        }
      }
    },
    "help.section.employees.item.3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عيّن دوراً واحداً أو أكثر (مثل: باريستا، مطبخ)."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এক বা একাধিক ভূমিকা নিযুক্ত করুন (যেমন বারিস্তা, রান্নাঘর)।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assign one or more roles (e.g. Barista, Kitchen)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asigna uno o más roles (p. ej. Barista, Cocina)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक या अधिक भूमिकाएँ सौंपें (जैसे बारिस्ता, रसोई)।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分配一个或多个职位（如咖啡师、厨房）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指派一個或多個職位(例如咖啡師、廚房)。"
          }
        }
      }
    },
    "help.section.employees.item.4" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد أجراً بالساعة وحدوداً أسبوعية للساعات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ঘণ্টা ভিত্তিক হার ও সাপ্তাহিক ঘণ্টার সীমা সেট করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set an hourly rate and weekly hour limits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece un salario por hora y límites horarios semanales."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रति घंटा दर और साप्ताहिक घंटों की सीमा सेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置时薪与每周时数上限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定時薪與每週時數上限。"
          }
        }
      }
    },
    "help.section.employees.item.5" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد ساعات اليوم التي يكون متاحاً فيها للعمل."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিটি দিনের কোন ঘণ্টায় তারা কাজের জন্য উপলব্ধ তা চিহ্নিত করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mark which hours of each day they are available to work."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marca qué horas de cada día están disponibles para trabajar."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चिह्नित करें कि वे प्रत्येक दिन के किन घंटों में काम के लिए उपलब्ध हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "标记每天可工作的时段。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "標記他們每天可工作的時段。"
          }
        }
      }
    },
    "help.section.employees.item.6" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على موظف لرؤية تفاصيله أو سجل ورديّاته."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "তাদের বিস্তারিত বা শিফট ইতিহাস দেখতে কোনো কর্মচারীতে ট্যাপ করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap an employee to see their details or shift history."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca un empleado para ver sus detalles o historial de turnos."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कर्मचारी के विवरण या शिफ़्ट इतिहास को देखने के लिए उन पर टैप करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击员工以查看详细信息或班次历史。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點選員工以查看其詳細資訊或班次歷史。"
          }
        }
      }
    },
