    "onboarding.page.shifts.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدد المناوبات التي تشغّلها كل أسبوع بأوقات البدء، أوقات النهاية، والأدوار المطلوبة. تُعاد المناوبات في كل مرة تنشئ فيها جدولاً."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "শুরু সময়, শেষ সময় এবং প্রয়োজনীয় ভূমিকা সহ আপনি প্রতি সপ্তাহে যে শিফট চালান তা সংজ্ঞায়িত করুন। আপনি প্রতিবার রোস্টার তৈরি করার সময় শিফট পুনঃব্যবহৃত হয়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define the shifts you run each week with start times, end times, and required roles. Shifts are reused every time you build a rota."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define los turnos que organizas cada semana con horas de inicio, fin y los roles necesarios. Los turnos se reutilizan cada vez que generas un horario."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आरंभ समय, समाप्ति समय और आवश्यक भूमिकाओं के साथ हर सप्ताह की शिफ्टें परिभाषित करें। हर बार रोस्टर बनाने पर शिफ्टें पुन: उपयोग की जाती हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用开始时间、结束时间和所需角色定义每周运行的班次。每次生成排班表时班次都会被复用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用開始時間、結束時間和所需角色定義每週運行的班次。每次產生排班表時班次都會被複用。"
          }
        }
      }
    },
