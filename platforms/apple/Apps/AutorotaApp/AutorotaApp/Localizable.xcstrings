    "onboarding.page.welcome.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الطريقة البسيطة لجدولة المناوبات في مقهاك. أعدّ فريقك، حدّد المناوبات، وأنشئ جداول أسبوعية في دقائق."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার ক্যাফের জন্য শিফট শিডিউল করার সহজ উপায়। আপনার দল সেট আপ করুন, শিফট সংজ্ঞায়িত করুন এবং কয়েক মিনিটে সাপ্তাহিক রোস্টার তৈরি করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The simple way to schedule shifts for your cafe. Set up your team, define your shifts, and generate weekly rotas in minutes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La forma sencilla de programar turnos para tu cafetería. Configura tu equipo, define los turnos y genera horarios semanales en minutos."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके कैफ़े के लिए शिफ्ट शेड्यूल करने का सरल तरीका। अपनी टीम सेट करें, शिफ्ट परिभाषित करें और मिनटों में साप्ताहिक रोस्टर जेनरेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为咖啡馆安排班次的简单方式。设置团队、定义班次，几分钟内生成每周排班表。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為咖啡館安排班次的簡單方式。設定團隊、定義班次，幾分鐘內產生每週排班表。"
          }
        }
      }
    },
