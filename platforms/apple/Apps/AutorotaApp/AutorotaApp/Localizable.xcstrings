    "There are no employees to send the rota to.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد موظفون لإرسال الجدول إليهم."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রোটা পাঠানোর জন্য কোনো কর্মচারী নেই।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay empleados a quienes enviar el horario."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रोटा भेजने के लिए कोई कर्मचारी नहीं है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有可发送排班表的员工。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有可傳送排班表的員工。"
          }
        }
      }
    },
    "This Week": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الأسبوع"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই সপ্তাহ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta semana"
          }
        },
        "hi": {
          "stringUnit": {
