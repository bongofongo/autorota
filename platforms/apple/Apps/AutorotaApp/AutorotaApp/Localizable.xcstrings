    },
    "Your Autorota data was found on iCloud. Would you like to download it to this device?": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم العثور على بيانات Autorota الخاصة بك على iCloud. هل تريد تنزيلها على هذا الجهاز؟"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার Autorota তথ্য iCloud-এ পাওয়া গেছে। আপনি কি এটি এই ডিভাইসে ডাউনলোড করতে চান?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se encontraron tus datos de Autorota en iCloud. ¿Quieres descargarlos a este dispositivo?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका Autorota डेटा iCloud पर मिला। क्या आप इसे इस डिवाइस पर डाउनलोड करना चाहेंगे?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 iCloud 上找到了您的 Autorota 数据。要下载到此设备吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 iCloud 上找到您的 Autorota 資料。要下載到此裝置嗎?"
          }
        }
      }
    },
    "e.g. Hi {first_name},": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مثال: مرحباً {first_name}،"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "যেমন: হাই {first_name},"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "p. ej. Hola {first_name},"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जैसे: नमस्ते {first_name},"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例如：嗨 {first_name}，"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "例如:嗨 {first_name},"
          }
        }
      }
    },
    "e.g. Let me know if any clashes.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مثال: أعلمني إن وُجِد أي تعارض."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "যেমন: কোনো সংঘর্ষ থাকলে আমাকে জানান।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "p. ej. Avísame si hay algún conflicto."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जैसे: यदि कोई टकराव हो तो मुझे बताएँ।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例如：如有冲突请告诉我。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "例如:如有衝突請告訴我。"
          }
        }
      }
    },
    "help.intro": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يساعدك Autorota على إنشاء جداول ورديات أسبوعية لمقهاك. اتبع هذه الخطوات للبدء:"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorota আপনাকে আপনার ক্যাফের জন্য সাপ্তাহিক শিফট সময়সূচী তৈরিতে সাহায্য করে। শুরু করতে এই পদক্ষেপগুলি অনুসরণ করুন:"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorota helps you create weekly shift schedules for your cafe. Follow these steps to get started:"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorota te ayuda a crear horarios semanales de turnos para tu cafetería. Sigue estos pasos para empezar:"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorota आपको अपने कैफ़े के लिए साप्ताहिक शिफ़्ट शेड्यूल बनाने में मदद करता है। शुरू करने के लिए इन चरणों का पालन करें:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorota 帮助您为咖啡馆创建每周班次表。请按以下步骤开始："
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorota 協助您為咖啡廳建立每週的排班表。請依照下列步驟開始使用:"
          }
        }
      }
    },
