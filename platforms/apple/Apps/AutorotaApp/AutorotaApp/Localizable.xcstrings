    "Saves will appear here as you edit schedules.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستظهر عمليات الحفظ هنا أثناء تعديلك للجداول."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি যখন সময়সূচী সম্পাদনা করবেন, সংরক্ষণগুলি এখানে দেখা যাবে।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los guardados aparecerán aquí a medida que edites los horarios."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जैसे ही आप शेड्यूल संपादित करेंगे, सहेजी गई प्रतियाँ यहाँ दिखाई देंगी।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑排班表时，保存记录会显示在此。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "編輯排班表時,儲存紀錄會顯示於此。"
          }
        }
      }
    },
