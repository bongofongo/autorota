    "This will overwrite the current schedule for week of %@ with the state from this save. This cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى الكتابة فوق الجدول الحالي لأسبوع %@ بالحالة من هذا الحفظ. لا يمكن التراجع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এটি %@ সপ্তাহের বর্তমান সময়সূচীকে এই সেভের অবস্থা দিয়ে প্রতিস্থাপন করবে। এটি পূর্বাবস্থায় ফেরানো যাবে না।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto sobrescribirá el horario actual de la semana del %@ con el estado de este guardado. No se puede deshacer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह %@ सप्ताह के मौजूदा शेड्यूल को इस सेव की स्थिति से अधिलेखित कर देगा। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会用本次保存的状态覆盖 %@ 那周的当前排班表。此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會以此次儲存的狀態覆寫 %@ 那週的目前排班表。此操作無法復原。"
          }
        }
      }
    },
