    "help.section.shifts.item.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحدّد الورديات الفترات التي تجدولها كل أسبوع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "শিফট প্রতি সপ্তাহে আপনার সময়সূচীর স্লট সংজ্ঞায়িত করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shifts define the slots you schedule each week."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los turnos definen los espacios que programas cada semana."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "शिफ़्टें उन स्लॉट्स को परिभाषित करती हैं जिन्हें आप हर सप्ताह शेड्यूल करते हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "班次定义每周要排的时段。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "班次定義每週要排的時段。"
          }
        }
      }
    },
    "help.section.shifts.item.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد الاسم ووقت البداية والنهاية واليوم من الأسبوع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নাম, শুরুর সময়, শেষ সময় ও সপ্তাহের দিন সেট করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set a name, start time, end time, and day of the week."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece nombre, hora de inicio, hora de fin y día de la semana."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नाम, प्रारंभ समय, समाप्ति समय और सप्ताह का दिन सेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置名称、开始时间、结束时间与星期几。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定名稱、開始時間、結束時間與星期幾。"
          }
        }
      }
    },
    "help.section.shifts.item.3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر الأدوار المطلوبة وعدد الموظفين."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "কোন ভূমিকা প্রয়োজন এবং কতজন কর্মী চয়ন করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose which roles are needed and how many staff."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige qué roles se necesitan y cuánto personal."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चुनें कि कौन सी भूमिकाएँ चाहिए और कितने कर्मचारी।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择所需的职位以及人员数量。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選擇所需的職位以及人員數量。"
          }
        }
      }
    },
    "help.section.shifts.item.4" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُعاد استخدام الورديات في كل مرة تولّد فيها جدولاً."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিবার রোটা জেনারেট করার সময় শিফট পুনরায় ব্যবহৃত হয়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shifts are reused every time you generate a rota."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los turnos se reutilizan cada vez que generas un horario."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हर बार जब आप रोटा जनरेट करते हैं तो शिफ़्टें पुनः उपयोग की जाती हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每次生成排班表时都会重复使用班次。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每次產生排班表時都會重複使用班次。"
          }
        }
      }
    },
    "help.step.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف موظفيك وأدوارهم"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার কর্মচারী ও তাদের ভূমিকা যোগ করুন"
          }
        },
