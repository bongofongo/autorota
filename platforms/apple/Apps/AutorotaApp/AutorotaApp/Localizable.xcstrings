        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার বিনামূল্যের ট্রায়াল শেষ হয়েছে। আপনি এখনও ডেটা দেখতে ও এক্সপোর্ট করতে পারেন, তবে কেনার আগে নতুন এডিট স্থগিত।"
          }
