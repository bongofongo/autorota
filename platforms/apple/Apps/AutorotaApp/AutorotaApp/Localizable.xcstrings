    "Adjusts availability, status, and chart colors so they remain distinguishable for the selected type of color vision." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يضبط ألوان التوفر والحالة والمخططات بحيث تبقى قابلة للتمييز وفق نوع رؤية الألوان المحدد."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নির্বাচিত বর্ণদৃষ্টির জন্য পার্থক্য বজায় রাখতে উপলব্ধতা, স্ট্যাটাস ও চার্টের রং সমন্বয় করে।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta los colores de disponibilidad, estado y gráficos para que sigan siendo distinguibles según el tipo de visión de color seleccionado."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपलब्धता, स्थिति और चार्ट रंगों को समायोजित करता है ताकि चयनित रंग दृष्टि प्रकार के लिए वे पहचान में रहें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整可用时段、状态与图表颜色，使所选色觉类型下仍可清楚区分。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "調整可用時段、狀態與圖表顏色,讓所選色覺類型下仍能清楚區分。"
          }
        }
      }
    },
