    "You can review or edit any employee from the picker below.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك مراجعة أو تعديل أي موظف من المنتقي أدناه."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নিচের পিকার থেকে যেকোনো কর্মচারী পর্যালোচনা বা সম্পাদনা করতে পারেন।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes revisar o editar cualquier empleado desde el selector de abajo."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप नीचे दिए गए पिकर से किसी भी कर्मचारी की समीक्षा या संपादन कर सकते हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您可以从下方选择器查看或编辑任何员工。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您可以從下方選單檢視或編輯任何員工。"
          }
        }
      }
    },
    "You're All Set": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل شيء جاهز"
          }
        },
