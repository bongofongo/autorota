    "Head to the Employees tab to add your first team member, then create shifts and generate your rota." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "توجَّه إلى تبويب الموظفين لإضافة أول عضو في فريقك، ثم أنشئ الورديات وولّد الجدول."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "কর্মচারী ট্যাবে গিয়ে আপনার প্রথম দলের সদস্য যোগ করুন, তারপর শিফট তৈরি করে আপনার রোটা জেনারেট করুন।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ve a la pestaña Empleados para añadir el primer miembro del equipo, luego crea turnos y genera el horario."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपना पहला टीम सदस्य जोड़ने के लिए कर्मचारी टैब पर जाएँ, फिर शिफ़्ट बनाएँ और अपना रोटा जनरेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前往「员工」标签页添加首位团队成员，然后创建班次并生成排班表。"
          }
        },
        "zh-Hant" : {
