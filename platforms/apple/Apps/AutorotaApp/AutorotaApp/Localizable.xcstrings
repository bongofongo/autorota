    "help.section.employees.item.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على زر + لإضافة موظف جديد."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নতুন কর্মচারী যোগ করতে + বোতামে ট্যাপ করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the + button to add a new employee."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca el botón + para añadir un nuevo empleado."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नया कर्मचारी जोड़ने के लिए + बटन पर टैप करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击 + 按钮添加新员工。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點選 + 按鈕新增員工。"
          }
        }
      }
    },
    "help.section.employees.item.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد الاسم الأول واسم العائلة والاسم المستعار الاختياري."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "তাদের প্রথম নাম, শেষ নাম ও ঐচ্ছিক ডাকনাম সেট করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set their first name, last name, and optional nickname."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece su nombre, apellido y apodo opcional."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उनका पहला नाम, अंतिम नाम और वैकल्पिक उपनाम सेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置员工的名字、姓氏与可选的昵称。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定員工的名字、姓氏與選填的暱稱。"
          }
        }
      }
    },
    "help.section.employees.item.3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عيّن دوراً واحداً أو أكثر (مثل: باريستا، مطبخ)."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এক বা একাধিক ভূমিকা নিযুক্ত করুন (যেমন বারিস্তা, রান্নাঘর)।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assign one or more roles (e.g. Barista, Kitchen)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asigna uno o más roles (p. ej. Barista, Cocina)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक या अधिक भूमिकाएँ सौंपें (जैसे बारिस्ता, रसोई)।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分配一个或多个职位（如咖啡师、厨房）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指派一個或多個職位(例如咖啡師、廚房)。"
          }
        }
      }
    },
    "help.section.employees.item.4" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد أجراً بالساعة وحدوداً أسبوعية للساعات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ঘণ্টা ভিত্তিক হার ও সাপ্তাহিক ঘণ্টার সীমা সেট করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set an hourly rate and weekly hour limits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece un salario por hora y límites horarios semanales."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रति घंटा दर और साप्ताहिक घंटों की सीमा सेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置时薪与每周时数上限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定時薪與每週時數上限。"
          }
        }
      }
    },
    "help.section.employees.item.5" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدّد ساعات اليوم التي يكون متاحاً فيها للعمل."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিটি দিনের কোন ঘণ্টায় তারা কাজের জন্য উপলব্ধ তা চিহ্নিত করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mark which hours of each day they are available to work."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marca qué horas de cada día están disponibles para trabajar."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चिह्नित करें कि वे प्रत्येक दिन के किन घंटों में काम के लिए उपलब्ध हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "标记每天可工作的时段。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "標記他們每天可工作的時段。"
          }
        }
      }
    },
    "help.section.employees.item.6" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على موظف لرؤية تفاصيله أو سجل ورديّاته."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "তাদের বিস্তারিত বা শিফট ইতিহাস দেখতে কোনো কর্মচারীতে ট্যাপ করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap an employee to see their details or shift history."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca un empleado para ver sus detalles o historial de turnos."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कर्मचारी के विवरण या शिफ़्ट इतिहास को देखने के लिए उन पर टैप करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击员工以查看详细信息或班次历史。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點選員工以查看其詳細資訊或班次歷史。"
          }
        }
      }
