    "license.modal.future_tier.body" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه الفئة غير متاحة بعد. سنعلمك عند إطلاقها — اهتمامك يساعدنا في تحديد الأولويات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই টিয়ার এখনও উপলব্ধ নয়। প্রকাশের সময় আপনাকে জানাবো — আপনার আগ্রহ অগ্রাধিকার নির্ধারণে সাহায্য করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This tier isn't available yet. We'll let you know when it ships — your interest helps us prioritise."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este nivel aún no está disponible. Te avisaremos cuando esté listo — tu interés nos ayuda a priorizar."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह टियर अभी उपलब्ध नहीं है। शुरू होने पर हम आपको सूचित करेंगे — आपकी रुचि प्राथमिकता तय करने में मदद करती है।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此版本尚未推出。准备就绪后会通知您 — 您的关注帮助我们排定优先级。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此版本尚未推出。準備就緒後會通知您 — 您的關注幫助我們排定優先順序。"
          }
