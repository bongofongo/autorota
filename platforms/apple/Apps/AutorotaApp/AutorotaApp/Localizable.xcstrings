        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este nivel aún no está disponible. Te avisaremos cuando esté listo — tu interés nos ayuda a priorizar."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह टियर अभी उपलब्ध नहीं है। शुरू होने पर हम आपको सूचित करेंगे — आपकी रुचि प्राथमिकता तय करने में मदद करती है।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此版本尚未推出。准备就绪后会通知您 — 您的关注帮助我们排定优先级。"
          }
        },
        "zh-Hant" : {
