    "Used by Bulk Send. `{first_name}`, `{last_name}`, `{name}` are substituted per recipient." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُستخدَم في الإرسال الجماعي. تُستبدَل `{first_name}` و`{last_name}` و`{name}` حسب كل مستلم."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "বাল্ক পাঠানোর দ্বারা ব্যবহৃত। `{first_name}`, `{last_name}`, `{name}` প্রতি প্রাপকের জন্য প্রতিস্থাপিত হয়।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usado por Envío masivo. `{first_name}`, `{last_name}`, `{name}` se sustituyen por destinatario."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बल्क भेजें द्वारा उपयोग किया जाता है। `{first_name}`, `{last_name}`, `{name}` प्रत्येक प्राप्तकर्ता के लिए प्रतिस्थापित होते हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于批量发送。`{first_name}`、`{last_name}`、`{name}` 会按收件人替换。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於批次傳送。`{first_name}`、`{last_name}`、`{name}` 會依收件人替換。"
          }
        }
      }
    },
