    "onboarding.page.team.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف موظفيك في تبويب الموظفين. حدد لهم الأدوار، اضبط أجورهم بالساعة، ووسم الأيام التي يمكنهم العمل فيها."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Employees ট্যাবে আপনার কর্মীদের যোগ করুন। তাদের ভূমিকা দিন, ঘণ্টাপ্রতি হার সেট করুন এবং কোন কোন দিনে তারা কাজ করতে পারবে তা চিহ্নিত করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add your employees in the Employees tab. Give them roles, set their hourly rates, and mark which days they can work."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade a tus empleados en la pestaña Empleados. Asígnales roles, fija su tarifa por hora y marca los días en que pueden trabajar."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Employees टैब में अपने कर्मचारी जोड़ें। उन्हें भूमिकाएँ दें, उनकी प्रति घंटा दर सेट करें और उन दिनों को चिह्नित करें जब वे काम कर सकते हैं।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「员工」标签页中添加员工。为他们指定角色，设置时薪，并标记他们可工作的日期。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「員工」標籤頁中新增員工。為他們指定角色，設定時薪，並標記他們可工作的日期。"
          }
        }
      }
    },
