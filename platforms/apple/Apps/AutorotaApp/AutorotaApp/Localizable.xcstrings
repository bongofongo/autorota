    "Tap a highlighted employee to swap" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على موظف مميَّز للتبديل"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "অদলবদল করতে হাইলাইট করা কর্মচারীকে ট্যাপ করুন"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca un empleado resaltado para intercambiar"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्वैप के लिए हाइलाइट किए गए कर्मचारी पर टैप करें"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击高亮的员工进行对调"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點選反白的員工進行對調"
          }
        }
      }
    },
    "Tap Generate to create a schedule for this week." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على «توليد» لإنشاء جدول لهذا الأسبوع."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই সপ্তাহের সময়সূচী তৈরি করতে জেনারেট ট্যাপ করুন।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca Generar para crear el horario de esta semana."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस सप्ताह का शेड्यूल बनाने के लिए जनरेट पर टैप करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击「生成」为本周创建排班表。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點選「產生」為本週建立排班表。"
          }
        }
      }
    },
    "Tapping a row opens a draft. iMessage and Mail auto-mark when you tap Send. WhatsApp opens a draft you'll need to send manually." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يفتح الضغط على صف مسودَّة. يضع iMessage والبريد العلامة تلقائياً عند الضغط على «إرسال». يفتح WhatsApp مسودَّة عليك إرسالها يدوياً."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি সারিতে ট্যাপ করলে একটি খসড়া খোলে। iMessage এবং Mail আপনি Send ট্যাপ করলে স্বয়ংক্রিয়ভাবে চিহ্নিত হয়। WhatsApp একটি খসড়া খোলে যা আপনাকে নিজে পাঠাতে হবে।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al tocar una fila se abre un borrador. iMessage y Mail se marcan automáticamente al pulsar Enviar. WhatsApp abre un borrador que tendrás que enviar manualmente."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी पंक्ति पर टैप करने से एक ड्राफ़्ट खुलता है। iMessage और Mail भेजें टैप करने पर अपने आप चिह्नित हो जाते हैं। WhatsApp एक ड्राफ़्ट खोलता है जिसे आपको स्वयं भेजना होगा।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击一行会打开草稿。iMessage 和 Mail 在点击「发送」时自动标记。WhatsApp 会打开草稿，需要您手动发送。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點選一列會開啟草稿。iMessage 與 Mail 在按下「傳送」時自動標記。WhatsApp 會開啟草稿,需要您手動傳送。"
          }
        }
      }
    },
