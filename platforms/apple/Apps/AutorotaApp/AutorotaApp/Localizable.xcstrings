    "help.section.settings.example.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تبديل التطبيق إلى الإسبانية: افتح اللغة واختر Español؛ أعد تشغيل التطبيق للتطبيق."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "অ্যাপটি স্প্যানিশে স্যুইচ করুন: ভাষা খুলুন এবং Español নির্বাচন করুন; প্রয়োগ করতে অ্যাপ পুনরায় চালু করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Switch the app to Spanish: open Language and pick Español; restart the app to apply."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia la app al español: abre Idioma y elige Español; reinicia la app para aplicar el cambio."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऐप को स्पैनिश में बदलें: भाषा खोलें और Español चुनें; लागू करने के लिए ऐप पुनः आरंभ करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将应用切换为西班牙语：打开「语言」并选择 Español；重启应用以生效。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將應用切換為西班牙語：開啟「語言」並選擇 Español；重啟應用以生效。"
          }
        }
      }
    },
    "help.section.settings.example.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إعادة تشغيل الإعداد: انقر على ‘إعادة تشغيل الإعداد’ لاستعادة جولة الترحيب وإعادة تعيين تلميحات التدريب."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "অনবোর্ডিং পুনরায় চালান: ‘Replay onboarding’ ট্যাপ করুন যাতে স্বাগত ট্যুর ফিরে আসে এবং কোচিং টিপস পুনরায় সেট হয়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Replay onboarding: tap ‘Replay onboarding’ to bring back the welcome tour and reset coaching tips."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repetir la introducción: toca ‘Repetir introducción’ para volver a ver el recorrido de bienvenida y restablecer los consejos guiados."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऑनबोर्डिंग दोबारा चलाएँ: ‘ऑनबोर्डिंग दोबारा चलाएँ’ पर टैप करें ताकि स्वागत टूर वापस आए और कोचिंग टिप्स रीसेट हों।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重新播放入门引导：点击「重新播放入门引导」以重新展示欢迎之旅并重置指导提示。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
