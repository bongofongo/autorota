    "help.section.exceptions.example.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مايا مريضة الثلاثاء: افتح توفّرها لذلك التاريخ واضبط ساعات الصباح على لا."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "মায়া মঙ্গলবার অসুস্থ: সেই তারিখের জন্য তার প্রাপ্যতা খুলুন এবং সকালের ঘন্টাগুলি না-তে সেট করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya is sick Tuesday: open her availability for that date and set the morning hours to No."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya está enferma el martes: abre su disponibilidad para esa fecha y marca las horas de la mañana como No."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माया मंगलवार को बीमार हैं: उस तारीख के लिए उनकी उपलब्धता खोलें और सुबह के घंटों को नहीं पर सेट करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya 周二请病假：打开她当日的可用性并将上午时段设为「否」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maya 週二請病假：開啟她當日的可用性並將上午時段設為「否」。"
          }
        }
      }
    },
    "help.section.exceptions.example.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إغلاق في عطلة رسمية: افتح تجاوز قالب المناوبة في التاريخ المتأثر ووضع علامة \"ملغاة\"."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সরকারি ছুটির জন্য বন্ধ: প্রভাবিত তারিখে শিফট টেমপ্লেট ওভাররাইড খুলুন এবং বাতিল চিহ্নিত করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Closed for a public holiday: open the shift template override on the affected date and mark it cancelled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cerrado por festivo: abre la anulación de plantilla de turno en la fecha afectada y márcala como cancelada."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सार्वजनिक अवकाश के लिए बंद: प्रभावित तारीख पर शिफ्ट टेम्पलेट ओवरराइड खोलें और रद्द चिह्नित करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公共假期歇业：在受影响日期打开班次模板覆写并标记为取消。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公眾假期歇業：在受影響日期開啟班次範本覆寫並標記為取消。"
          }
        }
      }
    },
    "help.section.exceptions.item.1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم الاستثناءات للتغييرات لمرة واحدة في تاريخ معين."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নির্দিষ্ট তারিখের একবার পরিবর্তনের জন্য ব্যতিক্রম ব্যবহার করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use exceptions for one-off changes to a specific date."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa excepciones para cambios puntuales en una fecha concreta."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी विशिष्ट तिथि के लिए एक बार के परिवर्तनों के लिए अपवादों का उपयोग करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对特定日期的一次性变更使用例外。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對特定日期的一次性變更使用例外。"
          }
        }
      }
    },
    "help.section.exceptions.item.2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ثبّت موظفاً في وردية أو استبعده منها."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একজন কর্মচারীকে কোনো শিফটে স্থির করুন বা তাকে এর থেকে বাদ দিন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pin an employee to a shift or exclude them from one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fija a un empleado a un turno o exclúyelo de él."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी कर्मचारी को किसी शिफ़्ट के लिए तय करें या उसे शिफ़्ट से बाहर करें।"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将员工固定于某班次或排除在外。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將員工固定於某班次或排除於外。"
          }
        }
      }
    },
    "help.section.exceptions.item.3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "غيّر توفر موظف ليوم واحد فقط."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একজন কর্মচারীর একটি দিনের উপলব্ধতা পরিবর্তন করুন।"
          }
        },
        "en" : {
