---
import { Image } from "astro:assets";
import AppStoreBadge from "./AppStoreBadge.astro";
import { SUBLINE, href } from "../consts";
import phoneShot from "../assets/screenshots/iphone/rota-rota.png";
import padShot from "../assets/screenshots/ipad/prev-rota.png";
---

<section class="hero section-alt">
  <div class="wrap grid">
    <div class="copy">
      <h1 class="display">
        The week's rota,<br /><span class="accent">built in a tap.</span>
      </h1>
      <p class="lede">{SUBLINE}</p>
      <div class="cta">
        <AppStoreBadge />
        <a class="btn btn-quiet" href={href("/support")}>Questions? Support</a>
      </div>
      <p class="platforms">For iPhone and iPad · syncs through your own iCloud</p>
    </div>
    <div class="art" aria-hidden="true">
      <div class="pad">
        <Image
          src={padShot}
          alt=""
          widths={[520, 780, 1100]}
          sizes="(max-width: 900px) 84vw, 560px"
          loading="eager"
        />
      </div>
      <div class="phone">
        <Image
          src={phoneShot}
          alt=""
          widths={[300, 460, 640]}
          sizes="(max-width: 900px) 40vw, 250px"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    overflow: hidden;
    padding-block: clamp(56px, 8vw, 104px);
  }

  .grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .copy {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem;
  }

  .platforms {
    font-size: 0.9rem;
    color: var(--faint);
  }

  /* Overlapped iPad-behind / iPhone-front composition, App-Store-art style. */
  .art {
    position: relative;
    min-height: 340px;
  }

  .pad {
    /* the baked caption band sits in the top 21% — clip it off */
    clip-path: inset(21% 0 0 0 round 24px);
    transform: rotate(1.4deg) translateY(-8%);
    filter: drop-shadow(0 30px 45px rgb(var(--shadow-rgb) / 18%));
  }

  .phone {
    position: absolute;
    width: 42%;
    bottom: -6%;
    left: -4%;
    clip-path: inset(15.5% 0 0 0 round 20px);
    transform: rotate(-2deg);
    filter: drop-shadow(0 24px 38px rgb(var(--shadow-rgb) / 26%));
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .art {
      max-width: 560px;
      margin-top: 1rem;
    }

    .phone {
      width: 40%;
      left: 0;
    }
  }
</style>
