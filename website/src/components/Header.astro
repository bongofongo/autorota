---
import icon from "../assets/rota-icon.svg";
import { href } from "../consts";
---

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href={href("/")}>
      <img src={icon.src} alt="" width="30" height="30" />
      <span>autorota</span>
    </a>
    <div class="actions">
      <nav aria-label="Site">
        <a href={href("/support")}>Support</a>
        <a href={href("/privacy")}>Privacy</a>
      </nav>
      <button class="theme-toggle" type="button" aria-label="Toggle dark mode">
        <svg
          class="icon-moon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg
          class="icon-sun"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32 1.41-1.41"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector(".theme-toggle");
  const root = document.documentElement;
  const syncPressed = () => {
    toggle?.setAttribute("aria-pressed", String(root.dataset.theme === "dark"));
  };
  syncPressed();
  toggle?.addEventListener("click", () => {
    const next = root.dataset.theme === "dark" ? "light" : "dark";
    root.dataset.theme = next;
    try {
      sessionStorage.setItem("theme", next);
    } catch {}
    document
      .querySelector('meta[name="theme-color"]')
      ?.setAttribute("content", next === "dark" ? "#0d1520" : "#ffffff");
    syncPressed();
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--header-bg);
    -webkit-backdrop-filter: saturate(1.5) blur(14px);
    backdrop-filter: saturate(1.5) blur(14px);
    border-bottom: 1px solid var(--hairline);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .brand:hover {
    text-decoration: none;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  nav {
    display: flex;
    gap: 1.6rem;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
  }

  .theme-toggle:hover {
    color: var(--ink);
    background: var(--bg-alt);
  }

  .theme-toggle .icon-sun {
    display: none;
  }

  :global([data-theme="dark"]) .theme-toggle .icon-sun {
    display: block;
  }

  :global([data-theme="dark"]) .theme-toggle .icon-moon {
    display: none;
  }

  nav a {
    color: var(--muted);
    font-weight: 500;
    font-size: 0.95rem;
  }

  nav a:hover {
    color: var(--ink);
    text-decoration: none;
  }
</style>
