---
import { APP_STORE_URL } from "../consts";
---

{
  APP_STORE_URL ? (
    <a class="badge live" href={APP_STORE_URL}>
      <svg viewBox="0 0 384 512" width="20" height="20" aria-hidden="true" fill="currentColor">
        <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
      </svg>
      <span class="badge-text">
        <small>Download on the</small>
        App Store
      </span>
    </a>
  ) : (
    <span class="badge soon">
      Coming soon to the App&nbsp;Store · free at launch
    </span>
  )
}

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border-radius: 12px;
    line-height: 1.15;
  }

  .live {
    background: var(--ink);
    color: #fff;
    padding: 0.6rem 1.2rem;
  }

  .live:hover {
    text-decoration: none;
    background: #000;
  }

  .badge-text {
    display: flex;
    flex-direction: column;
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }

  .badge-text small {
    font-size: 0.68rem;
    font-weight: 500;
    opacity: 0.85;
  }

  .soon {
    display: inline-block;
    max-width: 100%;
    text-align: center;
    background: var(--ink);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.3rem;
    border-radius: 999px;
  }
</style>
