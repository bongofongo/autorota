---
// Three real steps of using the app; the third card's mini rota "generates"
// itself on scroll — the page's one theatrical moment, echoing the headline.
const days = [
  [28, 40],
  [52, 24],
  [36, 46],
  [60],
  [30, 34],
  [44, 28],
  [38],
];
---

<section class="section">
  <div class="wrap">
    <span class="eyebrow">How it works</span>
    <h2>Three steps, then it's Tuesday's problem no more.</h2>
    <div class="cards">
      <article class="card reveal">
        <h3><span class="step">1</span>Sketch your shifts</h3>
        <p>
          Days, times, roles, how many people you need — set the week's shape
          once and reuse it.
        </p>
        <div class="motif" aria-hidden="true">
          <span class="chip">Barista · 07:00–12:00</span>
          <span class="chip">Kitchen · 11:00–15:00</span>
          <span class="chip alt">Anyone · 16:00–21:00</span>
        </div>
      </article>
      <article class="card reveal">
        <h3><span class="step">2</span>Collect availability</h3>
        <p>
          Everyone marks their hours yes, maybe, or no on a simple grid — a
          weekly pattern plus one-off exceptions.
        </p>
        <div class="motif dots" aria-hidden="true">
          {
            [
              "y", "y", "m", "n", "y", "m", "y", "n", "y", "y", "m", "y",
              "n", "n", "y", "m", "y", "y", "n", "m", "y",
            ].map((v) => <i class={v} />)
          }
        </div>
      </article>
      <article class="card reveal">
        <h3><span class="step">3</span>Generate the week</h3>
        <p>
          One tap places everyone fairly — available, qualified, inside their
          hour limits. Then edit freely.
        </p>
        <div class="motif minirota" aria-hidden="true">
          {
            days.map((blocks, d) => (
              <div class="col">
                {blocks.map((h, i) => (
                  <i style={`height:${h}%; transition-delay:${(d * 2 + i) * 70}ms`} />
                ))}
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  h2 {
    max-width: 22ch;
    margin-bottom: 2.6rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .card {
    border: 1px solid var(--hairline);
    border-radius: var(--radius-card);
    padding: 1.7rem 1.6rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    background: var(--bg);
  }

  .card p {
    color: var(--muted);
    font-size: 0.98rem;
    flex-grow: 1;
  }

  .step {
    display: inline-grid;
    place-items: center;
    width: 1.7em;
    height: 1.7em;
    margin-right: 0.6em;
    border-radius: 50%;
    background: var(--blue-tint);
    color: var(--blue);
    font-size: 0.85em;
  }

  .motif {
    margin-top: 0.6rem;
    min-height: 88px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.45rem;
  }

  .chip {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--blue);
    background: var(--blue-tint);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
  }

  .chip.alt {
    color: var(--muted);
    background: var(--bg-alt);
  }

  /* availability dots */
  .dots {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 7px;
    align-content: flex-start;
    max-width: 200px;
  }

  .dots i {
    width: 20px;
    height: 20px;
    border-radius: 6px;
  }

  .dots .y { background: var(--blue); opacity: 0.85; }
  .dots .m { background: var(--blue-tint); }
  .dots .n { background: var(--bg-alt); border: 1px solid var(--hairline); }

  /* the mini rota that assembles itself */
  .minirota {
    flex-direction: row;
    align-items: stretch;
    gap: 7px;
    height: 88px;
    width: 100%;
  }

  .col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 4px;
  }

  .col i {
    border-radius: 5px;
    background: linear-gradient(180deg, var(--blue) 0%, var(--blue-deep) 100%);
    opacity: 0.9;
  }

  .col i:nth-child(2) {
    opacity: 0.35;
  }

  :global(html.js) .reveal .col i {
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.3, 1.1);
  }

  :global(html.js) .reveal.in-view .col i {
    transform: scaleY(1);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .reveal .col i {
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 820px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
